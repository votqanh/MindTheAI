{
  "manifest_version": 3,
  "name": "MindTheAI",
  "version": "1.0.0",
  "description": "Promoting responsible AI usage by tracking water impact and protecting your sensitive data.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://copilot.microsoft.com/*",
        "https://www.perplexity.ai/*",
        "https://www.google.com/search*"
      ],
      "js": ["format.js", "storage.js", "water.js", "privacy.js", "google_ai.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://localhost:3001/*"],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://grok.com/*",
    "https://x.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.perplexity.ai/*",
    "https://www.google.com/search*",
    "http://localhost:3001/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["overlay.css", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
